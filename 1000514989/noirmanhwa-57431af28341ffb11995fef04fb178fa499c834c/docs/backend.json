
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information and status",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "bio": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin", "owner"] },
        "isPremium": { "type": "boolean" },
        "isBanned": { "type": "boolean" },
        "equippedBorder": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "Real-time global chat messages",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "senderPhoto": { "type": "string" },
        "timestamp": { "type": "object" },
        "isOwner": { "type": "boolean" },
        "replyTo": { "type": "string" },
        "replyToUser": { "type": "string" },
        "replyToText": { "type": "string" }
      }
    },
    "Notification": {
      "title": "Notification",
      "description": "System-wide owner announcements",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "object" },
        "active": { "type": "boolean" }
      }
    },
    "CustomBorder": {
      "title": "CustomBorder",
      "description": "Owner-uploaded avatar borders",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "imageUrl": { "type": "string" },
        "tier": { "type": "string" },
        "createdBy": { "type": "string" }
      }
    },
    "Report": {
      "title": "Report",
      "description": "User feedback and error reports",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "type": { "type": "string", "enum": ["bug", "chapter"] },
        "chapterId": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "resolved"] },
        "timestamp": { "type": "object" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/backend/entities/UserProfile",
      "description": "User data nodes"
    },
    "/chat_messages/{messageId}": {
      "schema": "#/backend/entities/ChatMessage",
      "description": "Global chat stream"
    },
    "/notifications/{notifId}": {
      "schema": "#/backend/entities/Notification",
      "description": "Global announcements"
    },
    "/custom_borders/{borderId}": {
      "schema": "#/backend/entities/CustomBorder",
      "description": "Available avatar frames"
    },
    "/reports/{reportId}": {
      "schema": "#/backend/entities/Report",
      "description": "User report logs"
    }
  }
}
